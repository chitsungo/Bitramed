{
  "name": "bitramed",
  "version": "3.1.0",
  "private": true,
  "description": "quiz app",
  "scripts": {
    "start": "npx serve public",
    "build:css": "tailwindcss -i ./public/styles/tw-input.css -o ./public/styles/tailwind.css",
    "watch:css": "tailwindcss -i ./public/styles/tw-input.css -o ./public/styles/tailwind.css --watch",
    "lint:js": "eslint src --ext .js",
    "lint:css": "stylelint \"style.css\" \"styles/{tokens,base,layout,components,themes,auth,learner,admin,dialog}.css\"",
    "format": "prettier --write \"**/*.{js,json,css,html,mjs}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,html,mjs}\"",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "stylelint": "^16.17.0",
    "stylelint-config-standard": "^38.0.0",
    "tailwindcss": "^3.4.19"
  }
}
